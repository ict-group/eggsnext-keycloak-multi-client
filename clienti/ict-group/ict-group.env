# =============================================================================
# KEYCLOAK CONFIG - Compatibilità multi-versione
# =============================================================================
# Strategia: tutte le variabili rilevanti sono presenti e documentate.
# Keycloak ignora le variabili che non riconosce nella versione in uso.
# Attiva/commenta le variabili in base alla versione target indicata qui sotto.
# =============================================================================

# Versione target (documentativo, usato anche da pipeline/docker-compose esterni)
KEYCLOAK_VERSION=26.0.0

# ID cliente applicativo
CLIENT_ID=ict-group


# =============================================================================
# ADMIN CREDENTIALS
# =============================================================================

# v17–v25: variabili legacy per le credenziali admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=Expert0.

# v26+: le variabili admin sono state rinominate (le precedenti vengono ignorate)
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=Expert0.


# =============================================================================
# HOSTNAME
# =============================================================================

# Inserire solo il nome host, senza protocollo e senza slash finale.
# Il wrapper entrypoint aggiunge automaticamente https:// per v25+ (hostname v2)
# e gestisce KEYCLOAK_FRONTEND_URL per WildFly < v17.
KC_HOSTNAME=keycloak.ict-group.com

# URL separato per la console di amministrazione (opzionale, v25+)
# KC_HOSTNAME_ADMIN=keycloak.ict-group.com


# =============================================================================
# REVERSE PROXY
# =============================================================================

# v17–v23: modalità proxy monolitica (edge / reencrypt / passthrough)
# Deprecata in v24, RIMOSSA in v26 → non usare con v26+
KC_PROXY=reencrypt

# v17–v23: abilitava il forwarding degli header X-Forwarded-*
# Deprecata in v24, RIMOSSA in v26
# KC_PROXY_ADDRESS_FORWARDING=true

# v24+: sostituisce KC_PROXY — specifica quali header accettare dal reverse proxy
# Valori: forwarded | xforwarded
# - xforwarded → equivalente al vecchio KC_PROXY=edge (X-Forwarded-For/Proto/Host)
# - forwarded  → usa l'header RFC 7239 "Forwarded"
KC_PROXY_HEADERS=xforwarded

# v24+: necessario quando il reverse proxy termina TLS e parla HTTP con Keycloak
# (equivalente al vecchio KC_PROXY=edge combinato con KC_PROXY_HEADERS=xforwarded)
KC_HTTP_ENABLED=true


# =============================================================================
# DATABASE
# =============================================================================

# KC_DB: tipo di database (non il nome) — invariato da v17+
KC_DB=postgres

# KC_DB_URL: URL JDBC completo — invariato da v17+
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak_Ict-Group

# Alternativa componente per componente (utile se host/porta cambiano):
# KC_DB_URL_HOST=postgres
# KC_DB_URL_PORT=5432
# KC_DB_URL_DATABASE=keycloak_consoli

KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=Expert0.


# =============================================================================
# TEMA
# =============================================================================

KC_THEME=Ict-Group-theme


# =============================================================================
# HTTPS (opzionale se TLS è terminato dal reverse proxy)
# =============================================================================

# v26+: necessario se si usa un keystore custom (es. cacerts JKS)
# KC_HTTPS_KEY_STORE_FILE=/opt/keycloak/conf/server.keystore
# KC_HTTPS_KEY_STORE_PASSWORD=change-me
# KC_HTTPS_KEY_STORE_TYPE=JKS


# =============================================================================
# HEALTH & METRICS (opzionale ma consigliato)
# =============================================================================

KC_HEALTH_ENABLED=true
KC_METRICS_ENABLED=true


# =============================================================================
# RIEPILOGO CAMBIAMENTI PER VERSIONE
# =============================================================================
# v17     → Quarkus runtime introdotto; variabili KC_* diventano lo standard
# v20     → WildFly non più pubblicato; solo Quarkus
# v24     → KC_PROXY deprecato → usare KC_PROXY_HEADERS + KC_HTTP_ENABLED
#            KC_PROXY_ADDRESS_FORWARDING deprecato
# v25     → hostname v1 deprecato → KC_HOSTNAME deve includere https://
#            KC_HOSTNAME_STRICT_HTTPS rimosso (genera warning poi ignorato)
# v26     → KC_PROXY RIMOSSO definitivamente
#            KEYCLOAK_ADMIN/PASSWORD → KC_BOOTSTRAP_ADMIN_USERNAME/PASSWORD
#            KC_HOSTNAME_STRICT_HTTPS RIMOSSO definitivamente
# v26.5+  → Supporto KCRAW_ prefix per valori letterali con caratteri speciali ($)
# =============================================================================