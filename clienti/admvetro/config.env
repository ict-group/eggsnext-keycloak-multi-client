# Versione di Keycloak
# Nota: questo valore è utile per documentazione o pipeline custom.
# Docker Compose usa invece la variabile KEYCLOAK_VERSION presente nel file test.env della root.
KEYCLOAK_VERSION=24.0.0
CLIENT_ID=admvetro


# Configurazioni specifiche del cliente
# In locale viene sovrascritto dal docker-compose-test.yml con KC_HOSTNAME=localhost.
KC_HOSTNAME=keycloak.admvetro.com
KC_HOSTNAME_STRICT=true
KC_PROXY=reencrypt

# Database
# Valori corretti per Keycloak:
# KC_DB deve indicare il tipo di database, non il nome del database.
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak_admvetro
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=change-me

# Tema
KC_THEME=admvetro-theme