# Versione di Keycloak
KEYCLOAK_VERSION=24.0.0

# Configurazioni specifiche del cliente
KC_HOSTNAME=keycloak.errevi.com
KC_HOSTNAME_STRICT=true
KC_PROXY=reencrypt

# Database (opzionale, per immagini standalone)
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak_errevi
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=change-me

# Tema
KC_THEME=errevi-theme