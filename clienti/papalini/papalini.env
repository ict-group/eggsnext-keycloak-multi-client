# =============================================================================
# KEYCLOAK CONFIG - ALL CLIENT THEMES
# =============================================================================
# Profilo fittizio usato per caricare e testare tutti i temi cliente.
#
# Struttura attesa:
#
# clienti/all-client-themes/
# ├── all-client-themes.env
# ├── consoli.env
# └── themes/
#     ├── errevi-theme/
#     ├── admvetro-theme/
#     ├── consoli-theme/
#     ├── papalini-theme/
#     ├── poma-theme/
#     ├── ict-group-theme/
#     ├── proges-theme/
#     └── ...
#
# Lancio:
#
# docker compose --env-file clienti/all-client-themes/all-client-themes.env -f docker-compose-test.yml up --build
# =============================================================================


# =============================================================================
# VERSIONE / CLIENTE
# =============================================================================

KEYCLOAK_VERSION=26.0.0

# ID cliente fittizio usato dal docker-compose per risolvere:
# - ./clienti/${CLIENT_ID}/themes
# - ./clienti/${CLIENT_ID}/consoli.env
# - nome container
# - nome volume database
CLIENT_ID=all-client-themes


# =============================================================================
# PORTE LOCALI
# =============================================================================

KEYCLOAK_PORT=8080
POSTGRES_PORT=5432
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025


# =============================================================================
# ADMIN CREDENTIALS
# =============================================================================

# Compatibilità v17-v25
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=Expert0.

# Compatibilità v26+
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=Expert0.

# Variabili usate dal docker-compose
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=Expert0.


# =============================================================================
# HOSTNAME - PROFILO LOCALE
# =============================================================================
# Per all-client-themes conviene usare localhost.
# Non usare hostname reali dei clienti, perché questo profilo è solo una sandbox.
# =============================================================================

KC_HOSTNAME=http://localhost:8080
KC_HOSTNAME_STRICT=false
KC_HOSTNAME_STRICT_HTTPS=false

# Obsoleto / da NON usare in Keycloak 26
# KEYCLOAK_FRONTEND_URL=
# KC_HOSTNAME_ADMIN=


# =============================================================================
# REVERSE PROXY - PROFILO LOCALE
# =============================================================================
# In locale non siamo dietro reverse proxy.
# Con Keycloak 26 KC_PROXY è rimosso, quindi NON usarlo.
# =============================================================================

KC_HTTP_ENABLED=true

# Non impostare KC_PROXY con Keycloak 26+
# KC_PROXY=reencrypt

# In locale normalmente non serve.
# Se in futuro provi dietro Nginx/Traefik puoi riattivarlo.
# KC_PROXY_HEADERS=xforwarded


# =============================================================================
# DATABASE
# =============================================================================

KC_DB=postgres

# Nome database separato per il profilo all-client-themes
KEYCLOAK_DB_NAME=keycloak_all_client_themes
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=Expert0.

KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak_all_client_themes
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=Expert0.


# =============================================================================
# TEMA
# =============================================================================
# Questo profilo carica tutti i temi dentro:
#
# clienti/all-client-themes/themes
#
# Il tema di default può essere uno qualsiasi tra quelli copiati.
# Io lascerei ict-group-theme oppure keycloak.v2 e poi selezioni da admin.
# =============================================================================

KC_THEME=ict-group-theme


# =============================================================================
# HEALTH & METRICS
# =============================================================================

KC_HEALTH_ENABLED=true
KC_METRICS_ENABLED=true


# =============================================================================
# NOTE IMPORTANTI
# =============================================================================
# 1. Questo file va passato a docker compose con:
#
#    docker compose --env-file clienti/all-client-themes/all-client-themes.env -f docker-compose-test.yml up --build
#
# 2. Il file env_file nel compose può comunque puntare a:
#
#    ./clienti/${CLIENT_ID}/${CLIENT_ID}.env
#    ./clienti/${CLIENT_ID}/consoli.env
#
#    ma CLIENT_ID deve essere già noto a Docker Compose tramite --env-file.
#
# 3. Non usare hostname tipo keycloak.papalini.com qui.
#    Questo profilo serve solo a testare tutti i temi in locale.
#
# 4. Non mescolare temi Keycloak 7 WildFly con temi Keycloak 26 Quarkus
#    se hanno FTL custom non compatibili.
# =============================================================================